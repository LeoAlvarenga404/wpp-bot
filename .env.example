# Mercado Livre
ML_SITE_ID=MLB
ML_CATEGORY=MLB1648
ML_MIN_DISCOUNT=25
ML_AFFILIATE_TAG=

# Mercado Livre OAuth (DevCenter app)
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# Must match EXACTLY the redirect URI registered in the ML DevCenter app
ML_REDIRECT_URI=

# WhatsApp / Baileys
WA_AUTH_DIR=./auth_info
WA_TARGET_JID=

# Affiliate cache (manual JSON until Playwright adapter ships)
AFFILIATE_LINKS_PATH=./affiliate-links.json

# App
PORT=3000

# Scheduler (P0-1)
SCHEDULER_ENABLED=false
SCHEDULER_CRON='0 10,13,17,20 * * *'

# Category rotation (P1-12)
CATEGORY_WEIGHTS='MLB1648:3,MLB1000:2,MLB1051:2,MLB1276:1'

# Quiet hours (P0-3)
QUIET_START=23
QUIET_END=7
TZ=America/Sao_Paulo

# Affiliate disclaimer (P0-4)
AFFILIATE_DISCLAIMER='Link de afiliado. Posso receber comissão sem custo extra pra você.'

# Dedup (P0-2) — skip catalog ids posted within this window, days
DEDUP_WINDOW_DAYS=7

# Logging / Sentry (P0-7)
SENTRY_DSN=
LOG_LEVEL=info
NODE_ENV=development

# API key (P1-15) — header `x-api-key` required on /pipeline/* and /affiliate/*.
# Leave empty in dev to disable auth (with a warn log). MUST be set in prod.
API_KEY=

# Postgres / Prisma (P1-9)
DATABASE_URL='postgresql://wppbot:changeme@localhost:5432/wppbot?schema=public'

# Affiliate provider — 'json' (default, file cache) or 'playwright' (P2-19)
AFFILIATE_PROVIDER=json

# WhatsApp warmup / health (P1-13, P0-6)
WA_CHIP_FIRST_USE_DATE=2026-05-13
WA_MAX_RECONNECTS=10

# In-group commands (P2-26). Comma-separated admin JIDs; empty = open to all.
WA_CMD_ADMIN_JIDS=

# Curation (P1-10 / P1-16) — fake-discount filter + lowest-price badge.
# When CURATION_REQUIRE_HISTORY=false (default) catalogs with <7d history are
# allowed to publish. Set =true to block until enough history accrues.
CURATION_REQUIRE_HISTORY=false
CURATION_DISCOUNT_THRESHOLD=0.85
CURATION_MIN_HISTORY_DAYS=7
