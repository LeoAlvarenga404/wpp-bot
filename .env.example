# Mercado Livre
ML_SITE_ID=MLB
ML_CATEGORY=MLB1648
ML_MIN_DISCOUNT=25
ML_AFFILIATE_TAG=

# Mercado Livre OAuth (DevCenter app)
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# Must match EXACTLY the redirect URI registered in the ML DevCenter app
ML_REDIRECT_URI=

# WhatsApp / Baileys
WA_AUTH_DIR=./auth_info
WA_TARGET_JID=

# Affiliate cache (manual JSON until Playwright adapter ships)
AFFILIATE_LINKS_PATH=./affiliate-links.json

# App
PORT=3000

# Scheduler (P0-1)
SCHEDULER_ENABLED=false
SCHEDULER_CRON='0 10,13,17,20 * * *'

# Category rotation (P1-12)
CATEGORY_WEIGHTS='MLB1648:3,MLB1000:2,MLB1051:2,MLB1276:1'

# Quiet hours (P0-3)
QUIET_START=23
QUIET_END=7
TZ=America/Sao_Paulo

# Dedup (P0-2) — skip catalog ids posted within this window, days
DEDUP_WINDOW_DAYS=7

# Logging / Sentry (P0-7)
SENTRY_DSN=
LOG_LEVEL=info
NODE_ENV=development

# API key (P1-15) — header `x-api-key` required on /pipeline/* and /affiliate/*.
# Leave empty in dev to disable auth (with a warn log). MUST be set in prod.
API_KEY=

# Postgres / Prisma (P1-9)
# Inside Docker compose: use service DNS `postgres` and the in-container port
# (5432). For local-dev pointing at the compose postgres from the host, use
# `localhost:5433` (host port remapped to avoid clashing with a host Postgres).
DATABASE_URL='postgresql://wppbot:changeme@postgres:5432/wppbot?schema=public'
POSTGRES_PASSWORD=changeme

# Redis (BullMQ — Onda 3). Inside Docker compose: `redis:6379`. From the host
# the compose service is exposed on `localhost:6380`.
REDIS_URL=redis://redis:6379

# Affiliate provider — 'json' (default, file cache) or 'playwright' (P2-19)
AFFILIATE_PROVIDER=json

# WhatsApp warmup / health (P1-13, P0-6)
WA_CHIP_FIRST_USE_DATE=2026-05-13
WA_MAX_RECONNECTS=10

# In-group commands (P2-26). Comma-separated admin JIDs; empty = open to all.
WA_CMD_ADMIN_JIDS=

# Curation (P1-10 / P1-16) — fake-discount filter + lowest-price badge.
# When CURATION_REQUIRE_HISTORY=false (default) catalogs with <7d history are
# allowed to publish. Set =true to block until enough history accrues.
CURATION_REQUIRE_HISTORY=false
CURATION_DISCOUNT_THRESHOLD=0.85
CURATION_MIN_HISTORY_DAYS=7

# Headline generator (legacy formatItem path only — the ofertas caption no
# longer renders an AI hook). HEADLINE_PROVIDER: 'noop' (default, static hook
# pool, no API key) or 'deepseek'. Falls back to noop when DEEPSEEK_API_KEY is
# missing. Uses the same DEEPSEEK_API_KEY as the curation judge.
HEADLINE_PROVIDER=noop
HEADLINE_MODEL=deepseek-chat
HEADLINE_TEMPERATURE=0.9
HEADLINE_MAX_TOKENS=60
HEADLINE_TIMEOUT_MS=8000
HEADLINE_CACHE_PATH=./data/headlines.json
HEADLINE_CACHE_DAYS=30

# ──────────────────────────────────────────
# Premium Deal Curation
# ──────────────────────────────────────────

# Score gates
DEAL_SCORE_MIN=75
DEAL_SCORE_TOP=90
DEAL_SCORE_SUPER=95
# Per-channel dispatch caps (deals per tick). WA counts OFFERS, not messages —
# with WA_DIGEST_SIZE>1 they are grouped into a single digest message.
MAX_DEALS_PER_RUN_WA=4
MAX_DEALS_PER_RUN_TELEGRAM=10
# Deals per WA message. >1 groups the tick's approved deals into one digest
# message (fewer messages, same offers). 1 = legacy one-message-per-deal.
WA_DIGEST_SIZE=4

# Enrichment budget
DEAL_ENRICH_TOP_N=10
SELLER_CACHE_TTL_HOURS=24
SELLER_CACHE_FILE=./data/seller-cache.json

# History-related gates
DEAL_SCORE_INSUFFICIENT_HISTORY_PENALTY=25
DEAL_SCORE_MIN_DISCOUNT_NO_HISTORY=40

# Price-raise scam heuristic
PRICE_RAISE_PEAK_WINDOW_DAYS=14
PRICE_RAISE_BASELINE_WINDOW_DAYS=30
PRICE_RAISE_PEAK_RATIO=1.20
PRICE_RAISE_CURRENT_BASELINE_RATIO=0.95

# Scheduler — 'legacy' (one category per tick, current behavior)
# or 'batch' (collect all weighted categories, rank globally, top K)
SCHEDULER_MODE=legacy

# Optional weight overrides (defaults shown)
# DEAL_SCORE_W_DISCOUNT_MAX=20
# DEAL_SCORE_W_BELOW_MEDIAN_MAX=25
# DEAL_SCORE_W_LOWEST_30D=15
# DEAL_SCORE_W_LOWEST_14D=10
# DEAL_SCORE_W_LOWEST_7D=5
# DEAL_SCORE_W_OFFICIAL_STORE=10
# DEAL_SCORE_W_SELLER_REPUTATION_MAX=10
# DEAL_SCORE_W_FREE_SHIPPING=5
# DEAL_SCORE_W_INSTALLMENTS_NO_INTEREST=5
# DEAL_SCORE_W_HIGH_SOLD_QTY_MAX=5
# DEAL_SCORE_W_PRICE_STABILITY=5
# DEAL_SCORE_W_PRICE_RAISE_PENALTY=30
# DEAL_SCORE_W_USED_PENALTY=15
# DEAL_SCORE_W_DISCOUNT_FROM_ORIGINAL_ONLY=10
# DEAL_SCORE_W_ABOVE_MEDIAN_PENALTY=10
# DEAL_SCORE_W_UNKNOWN_SELLER=5

# ──────────────────────────────────────────
# Source abstraction
# ──────────────────────────────────────────

# Comma-separated list of source ids to register. Today: 'ml'.
# Future: 'ml,shopee,amazon'. Empty = all available.
SOURCES_ENABLED=ml

# One-shot backup of legacy stores before the source-abstraction key
# migration (price-history.json, posted-log.json → .pre-refactor-bak).
# Set to 'false' after the first successful post-refactor boot. Idempotent
# (the backup is skipped if the .bak file already exists).
SOURCES_MIGRATION_BACKUP=true

# ──────────────────────────────────────────
# Telegram publisher (Fase 1)
# ──────────────────────────────────────────

# BotFather token. Leave empty to disable Telegram publishing.
TELEGRAM_BOT_TOKEN=
# Channel/group chat_id (e.g. -1001234567890 or @meucanal). Seeded as an
# active telegram target on boot.
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────
# DeepSeek LLM judge (Fase 2)
# ──────────────────────────────────────────

# API key for the gray-zone curation judge. Empty = judge disabled.
DEEPSEEK_API_KEY=

# OpenAI-compatible chat model id. Swap for the v4-flash id when desired.
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=8000

# Gray-zone gate: approve only if verdict.confidence >= this.
JUDGE_MIN_CONFIDENCE=0.6
# Cost ceiling per scheduler tick; excess gray-zone deals wait for next tick.
JUDGE_MAX_CALLS_PER_TICK=20

# Copy A/B: 'false' forces variant A everywhere (instant rollback, no deploy).
COPY_AB_ENABLED=true

# Selo "menor preço em Xd ✓ monitorado há Nd" nos posts (calculado no enqueue).
# false = posts idênticos aos anteriores; não requer redeploy do Redis.
TRUST_BADGE_ENABLED=true

# ──────────────────────────────────────────
# Shopee (segunda fonte — Fase 3)
# ──────────────────────────────────────────

# Credenciais da API de afiliados (https://open-api.affiliate.shopee.com.br).
# Ambas ausentes => fonte desligada (só ML roda). Requer conta aprovada no
# programa Shopee Afiliados.
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=
# Warmup: false => Shopee acumula PriceHistory/auditoria mas não publica
# (gate rejeita com stage=source_warmup). Ligar após ~7 dias de histórico.
SHOPEE_DISPATCH_ENABLED=false
SHOPEE_KEYWORDS=teclado mecanico,mouse gamer,headset gamer,smartwatch,caixa de som bluetooth,carregador turbo,fone bluetooth,hub usb c
SHOPEE_LIMIT_PER_KEYWORD=20
SHOPEE_TIMEOUT_MS=8000
# Com 2 fontes, use SCHEDULER_MODE=batch para o tick varrer as duas.

# ──────────────────────────────────────────
# Price-history warmup (Fase 0)
# ──────────────────────────────────────────

# Run the full collect+score pipeline on schedule but DON'T enqueue sends.
# Use for the first 1-2 weeks so PriceHistory medians stabilize before
# automatic posting starts (anti-fake barrier needs >=7 days of history).
# SCHEDULER_ENABLED=true
# SCHEDULER_DISPATCH_ENABLED=false
