// Prisma schema for wpp-bot (P1-9).
//
// Generate client:  npm run prisma:generate
// Create migration: npm run prisma:migrate:dev
// Apply migrations: npm run prisma:migrate
// Visual browser:   npm run prisma:studio
//
// NOTE: Postgres is not yet provisioned. This scaffold lands so future tasks
// can refactor file-backed state (ml-auth, dedup, affiliate cache) into Prisma.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  // `native` covers the host running prisma migrate / studio; explicit
  // debian-openssl-3.0.x ships the engine into the Docker runtime image
  // (node:22-bookworm-slim, with openssl 3.x) without a host-side regen.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

// ---------------------------------------------------------------------------
// Catalog state
// ---------------------------------------------------------------------------

model Product {
  catalogId  String   @id
  title      String?
  thumbnail  String?
  domainId   String?
  lastSeenAt DateTime @default(now())
}

// Price observations recorded by CurationService. No FK to Product — the
// curation pipeline records prices for catalogIds it discovers in raw feeds
// before any Product row exists, and forcing a join here would cascade
// stub-product upserts into every record() call.
model PriceHistory {
  id                 BigInt   @id @default(autoincrement())
  catalogId          String
  itemId             String?
  priceCents         Int
  originalPriceCents Int?
  capturedAt         DateTime @default(now())

  @@index([catalogId, capturedAt])
}

// Outbound message audit log. Standalone — see comment on PriceHistory above.
model SentMessage {
  id        BigInt   @id @default(autoincrement())
  catalogId String
  targetJid String
  caption   String
  variant   String?
  digestId  String?
  sentAt    DateTime @default(now())

  @@index([catalogId, sentAt])
}

// Curation decision audit (Fase 2). One row per (catalogId, stage, day) —
// repeated rejections on the */1 cron only bump `count`. stage/outcome are
// strings, not enums, so a new stage doesn't require a migration (same
// rationale as WaTarget.channel) — e.g. Fase 3 added 'source_warmup'.
// No FK to Product — see PriceHistory note.
model CurationDecision {
  id           BigInt   @id @default(autoincrement())
  catalogId    String
  stage        String
  outcome      String
  day          String
  count        Int      @default(1)
  score        Int?
  priceCents   Int?
  reasons      Json?
  judgeVerdict Json?
  variant      String?
  // CuratorEdits JSON for panel approvals with light edits (issue #6).
  edits        Json?
  firstAt      DateTime @default(now())
  lastAt       DateTime @updatedAt

  @@unique([catalogId, stage, day])
  @@index([day, stage])
}

// Cache of long-URL → short-URL pairs resolved by the Playwright affiliate
// adapter. `longUrl` is the natural key — we always look up by the original
// product URL that came out of the source feed.
model AffiliateLink {
  longUrl     String   @id
  shortUrl    String
  generatedAt DateTime @default(now())
}

// Manually-registered ML coupons (ml-coupons-v1). scope/type/targetId are
// strings (not enums) so a new scope doesn't require a migration — same
// rationale as WaTarget.channel. Money in integer cents.
model Coupon {
  id            String   @id @default(cuid())
  code          String
  scope         String // 'SELLER' | 'PRODUCT'
  targetId      String
  type          String // 'PERCENT' | 'FIXED'
  value         Int
  capCents      Int?
  minCents      Int?
  firstBuy      Boolean  @default(false)
  perUser       Boolean  @default(false)
  validUntil    DateTime
  active        Boolean  @default(true)
  affiliateSafe Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([scope, targetId, active])
}

// Click-tracking short link (CTR): outgoing captions link to
// ${REDIRECT_BASE_URL}/r/{code}, GET /r/:code 302s to `url` and bumps
// `clicks`. dealKey/channel are free-form attribution strings (no FK —
// see PriceHistory note). Feature off while REDIRECT_BASE_URL is empty.
model ShortLink {
  id        String   @id @default(cuid())
  code      String   @unique
  url       String
  dealKey   String?
  channel   String?
  clicks    Int      @default(0)
  createdAt DateTime @default(now())
}

// Operational config editable from the curation panel with immediate effect
// (no container recreate). Values are strings; typing/validation and the
// db → env → default fallback live in OpsConfigService. Keys share the env
// var names (e.g. QUIET_HOURS_ENABLED) so the fallback chain stays obvious.
// New key = no migration.
model OpsConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Approval queue (curation panel): borderline deals — passed the gate but
// scored below AUTO_APPROVE_SCORE — wait here for a human verdict instead of
// going straight to the send queue. `snapshot` is the full ScoredDeal JSON,
// re-hydrated on approve so the deal re-enters the existing dispatch path
// (live price scrape, coupon, digest, dedup). status is a string, not an
// enum (same rationale as WaTarget.channel): PENDING | APPROVED | REJECTED |
// EXPIRED. Rows past `expiresAt` are discarded without sending — a stale
// price must never be published.
model PendingDeal {
  id        String    @id @default(cuid())
  catalogId String
  status    String    @default("PENDING")
  score     Int
  snapshot  Json
  // CuratorEdits JSON applied on approval; null when approved untouched.
  edits     Json?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  decidedAt DateTime?

  @@index([status, expiresAt])
  @@index([catalogId, status])
}

// Singleton row (id = 1) holding current ML OAuth tokens.
model MlToken {
  id           Int      @id @default(1)
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  userId       BigInt?
  scope        String
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Dedup, rate-limit, targeting (P0-2, P1-13, P2-25, P2-27)
// ---------------------------------------------------------------------------

model DedupEntry {
  catalogId String   @id
  postedAt  DateTime @default(now())

  @@index([postedAt])
}

// Generic counter bucket — e.g. WA messages/hour, WA messages/day.
// id is the unique key (e.g. "wa:hour:2026-05-13T18"), bucket is the family
// (e.g. "wa-hour" / "wa-day") for aggregate queries.
model WaCounter {
  id        String   @id
  bucket    String
  count     Int
  updatedAt DateTime @updatedAt
}

model WaTarget {
  jid     String  @id
  name    String?
  active  Boolean @default(true)
  // Publisher channel: 'wa' | 'telegram'. String (not enum) so adding a
  // channel doesn't require a schema migration.
  channel String  @default("wa")
}

model WaOptout {
  jid     String   @id
  addedAt DateTime @default(now())
}
